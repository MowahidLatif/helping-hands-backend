# Copy this file to .env and fill in your values.
# Never commit .env to git.

FLASK_APP=run.py
FLASK_ENV=development
JWT_SECRET=replace-with-a-random-32-char-string

# Stripe — get test keys from Stripe Dashboard -> Developers -> API keys (Test mode)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_CURRENCY=cad

# AWS RDS (PostgreSQL)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=donations
DB_USER=your_db_user
DB_SECRET_NAME=your-secrets-manager-secret-name
DB_SSLMODE=verify-full
DB_SSLROOTCERT=./global-bundle.pem
AWS_REGION=us-east-2

# S3 / MinIO (media uploads)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=media-dev
S3_USE_PATH_STYLE=true

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Email
FROM_EMAIL=no-reply@example.com

# OpenAI (for AI site generation)
OPENAI_API_KEY=sk-REPLACE_ME
